{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          119547
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      },
      {
        "name": "token_type_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": null,
  "loader": {
    "task": "fill-mask",
    "model_class": "AutoModelForMaskedLM",
    "model_type": "bert"
  },
  "eval": {
    "task": "fill-mask",
    "dataset": {
      "path": "Salesforce/wikitext",
      "name": "wikitext-2-raw-v1",
      "split": "test",
      "samples": 100,
      "columns_mapping": {
        "input_column": "text"
      }
    }
  }
}
