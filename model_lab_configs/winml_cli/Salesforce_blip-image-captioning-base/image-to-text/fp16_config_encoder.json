{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          384,
          384
        ],
        "value_range": [
          0,
          1
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "encoder_hidden_states"
      }
    ]
  },
  "optim": {
    "gelu_fusion": true,
    "layer_norm_fusion": true,
    "matmul_add_fusion": true
  },
  "quant": null,
  "compile": null,
  "loader": {
    "task": "image-feature-extraction",
    "model_class": "BlipVisionEncoderWrapper",
    "model_type": "blip"
  },
  "eval": {
    "task": "image-to-text",
    "dataset": {
      "path": "lmms-lab/flickr30k",
      "split": "test",
      "samples": 500,
      "columns_mapping": {
        "input_column": "image",
        "label_column": "caption"
      }
    }
  }
}
